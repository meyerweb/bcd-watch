                  <li>

          

                      <span>
                        <a href="https://developer.mozilla.org/docs/Web/JavaScript/Reference/Global_Objects/Promise/try">javascript ➞ builtins ➞ Promise ➞ try</a>
                      </span>
                    
                    <b><br></b> 
                    <span class="browsers">Added to <strong>Safari</strong></span> 
                    <b>&nbsp;➞&nbsp;</b>
                    <span class="ni3 engines"><strong>3 of 3</strong> engines</span>

